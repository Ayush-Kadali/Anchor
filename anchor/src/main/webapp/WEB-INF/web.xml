<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Anchor - Prototype</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ==================== FILTER ==================== -->
    <!-- AuthenticationFilter runs BEFORE every request.
         It checks if user has a valid session.
         If not logged in, redirects to login page.
         Skips: login, register, css, api endpoints -->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>com.anchor.servlets.AuthenticationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ==================== SERVLETS ==================== -->

    <!-- Login: handles authentication -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.anchor.servlets.LoginServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Register: handles new user creation -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.anchor.servlets.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- Logout: destroys session -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.anchor.servlets.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Device Scanner: REST API returning JSON list of serial ports -->
    <servlet>
        <servlet-name>DeviceScannerServlet</servlet-name>
        <servlet-class>com.anchor.servlets.DeviceScannerServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeviceScannerServlet</servlet-name>
        <url-pattern>/api/devices</url-pattern>
    </servlet-mapping>

    <!-- DB Test: tests JDBC connection to MySQL -->
    <servlet>
        <servlet-name>DbTestServlet</servlet-name>
        <servlet-class>com.anchor.servlets.DbTestServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DbTestServlet</servlet-name>
        <url-pattern>/dbtest</url-pattern>
    </servlet-mapping>

    <!-- Active Connections API: returns JSON for dashboard -->
    <servlet>
        <servlet-name>ActiveConnectionsServlet</servlet-name>
        <servlet-class>com.anchor.servlets.ActiveConnectionsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ActiveConnectionsServlet</servlet-name>
        <url-pattern>/api/connections</url-pattern>
    </servlet-mapping>

    <!-- Server Status: live view of active connections -->
    <servlet>
        <servlet-name>StatusServlet</servlet-name>
        <servlet-class>com.anchor.servlets.StatusServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StatusServlet</servlet-name>
        <url-pattern>/status</url-pattern>
    </servlet-mapping>

    <!-- Admin Actions: kick/block/privacy (Enhancement 3+4) -->
    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>com.anchor.servlets.AdminServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/admin/action</url-pattern>
    </servlet-mapping>

    <!-- Log Download: PDF generation with filters (Enhancement 2) -->
    <servlet>
        <servlet-name>LogDownloadServlet</servlet-name>
        <servlet-class>com.anchor.servlets.LogDownloadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogDownloadServlet</servlet-name>
        <url-pattern>/api/logs/download</url-pattern>
    </servlet-mapping>

    <!-- NOTE: TerminalWebSocket uses @ServerEndpoint annotation
         so it does NOT need to be configured here.
         Tomcat/Jetty detects it automatically. -->

    <!-- Session timeout: 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
</web-app>
